{
  "name": "claude-plugins",
  "version": "0.1.0",
  "description": "The safety layer Claude Code doesn't ship with — hooks that enforce, not suggest",
  "type": "module",
  "main": "cli/index.js",
  "bin": {
    "claude-plugins": "cli/index.js"
  },
  "scripts": {
    "test": "node --test tests/hooks/*.test.js tests/cli/*.test.js",
    "test:hooks": "node --test tests/hooks/*.test.js",
    "test:watch": "node --test --watch tests/hooks/*.test.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "plugins",
    "hooks",
    "safety",
    "developer-tools"
  ],
  "author": "Shaswata Tripathy",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "node-fetch": "^3.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ShaswataTripathy/claude-plugins"
  }
}
