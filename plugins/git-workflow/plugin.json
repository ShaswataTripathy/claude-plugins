{
  "name": "git-workflow",
  "version": "2.0.0",
  "description": "Complete git workflow for Claude Code — smart commits, branching, history cleanup, stash, sync, and undo",
  "author": "community",
  "components": ["skill", "hook"],
  "skills": [
    "commit.md",
    "branch.md",
    "cleanup.md",
    "sync.md",
    "undo.md",
    "stash.md",
    "log.md",
    "fixup.md"
  ],
  "hookFiles": ["protect.js"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{plugin_dir}/hooks/protect.js\""
          }
        ]
      }
    ]
  },
  "postInstall": "git-workflow v2 installed! Commands: /commit /branch /cleanup /sync /undo /stash /log /fixup"
}
